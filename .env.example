ANTHROPIC_API_KEY=
STOCKFISH_PATH=/usr/bin/stockfish
PORT=5000
DEBUG=false

# LLM provider: gemini (free) | groq (free) | anthropic (paid) | ollama (local)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
HF_TOKEN=
